# Firebase Configuration Example
# Скопируйте этот файл в .env и заполните ваши данные

# ============ FIREBASE CONFIGURATION ============

# Вариант 1: Использование пути к файлу (разработка)
FIREBASE_CREDENTIALS_PATH=/app/config/firebase-credentials.json

# Вариант 2: Использование JSON строки (production)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project","..."}

# ============ BACKEND CONFIGURATION ============
BACKEND_PORT=8000
OLLAMA_URL=http://localhost:11434
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-secret-key-change-in-production-123456789

# ============ REMOVED (больше не используются) ============
# DATABASE_URL больше не нужен - используется Firebase вместо PostgreSQL
